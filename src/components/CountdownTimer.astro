---
interface Props {
  dateIso: string;
  fuseau: string;
  confirme: boolean;
  id: string;
}

const { dateIso, fuseau, confirme, id } = Astro.props;
---

<countdown-timer
  data-target={dateIso}
  data-tz={fuseau}
  data-confirmed={confirme.toString()}
  data-id={id}
  aria-live="polite"
  aria-label="Compte à rebours"
>
  <div class="countdown-wrapper" data-digits>
    <!-- Server-rendered placeholder — replaced by JS immediately -->
    <noscript>
      <p style="color:var(--c-texte-secondaire)">Activez JavaScript pour voir le compte à rebours en direct.</p>
    </noscript>
    <div class="countdown-group">
      <div class="digit-box">
        <span class="digit-value" data-unit="days">--</span>
        <span class="digit-label">Jours</span>
      </div>
      <span class="digit-sep">:</span>
      <div class="digit-box">
        <span class="digit-value" data-unit="hours">--</span>
        <span class="digit-label">Heures</span>
      </div>
      <span class="digit-sep">:</span>
      <div class="digit-box">
        <span class="digit-value" data-unit="minutes">--</span>
        <span class="digit-label">Min</span>
      </div>
      <span class="digit-sep">:</span>
      <div class="digit-box">
        <span class="digit-value" data-unit="seconds">--</span>
        <span class="digit-label">Sec</span>
      </div>
    </div>
  </div>

  {!confirme && (
    <p class="estimated-notice" style="text-align:center;margin-top:0.75rem;">
      <span class="badge badge--estimated">Date estimée, non confirmée</span>
    </p>
  )}

  <div class="happened-banner" data-happened style="display:none" aria-hidden="true">
    C'est arrivé !
  </div>
</countdown-timer>

<script>
  class CountdownTimer extends HTMLElement {
    private interval: ReturnType<typeof setInterval> | null = null;
    private target!: Date;
    private previous: Record<string, string> = {};

    connectedCallback() {
      const isoRaw = this.dataset.target!;
      const tz = this.dataset.tz!;

      // Build a Date from the ISO string + timezone.
      // We use Intl to resolve the exact UTC offset for this date in the given tz.
      this.target = this.resolveDate(isoRaw, tz);

      this.tick();
      this.interval = setInterval(() => this.tick(), 1000);
    }

    disconnectedCallback() {
      if (this.interval) clearInterval(this.interval);
    }

    private resolveDate(iso: string, tz: string): Date {
      // Parse naive datetime and resolve to UTC via the given timezone
      const naive = new Date(iso + 'Z'); // treat as UTC temporarily
      try {
        // Get the offset of the target timezone at this date
        const formatter = new Intl.DateTimeFormat('en-US', {
          timeZone: tz,
          year: 'numeric', month: '2-digit', day: '2-digit',
          hour: '2-digit', minute: '2-digit', second: '2-digit',
          hour12: false,
        });
        // We need to find what UTC time corresponds to this local time in `tz`.
        // Strategy: parse the ISO as local in `tz` by binary-searching the offset.
        // Simpler approach: use the offset from the formatter.
        const parts = formatter.formatToParts(naive);
        const get = (type: string) => parts.find(p => p.type === type)?.value ?? '0';
        const localAtUTC = new Date(
          Date.UTC(+get('year'), +get('month') - 1, +get('day'),
                   +get('hour'), +get('minute'), +get('second'))
        );
        const offsetMs = localAtUTC.getTime() - naive.getTime();
        // The actual event time in UTC = naive - offset
        return new Date(naive.getTime() - offsetMs);
      } catch {
        // Fallback: treat the ISO string as-is (browser local)
        return new Date(iso);
      }
    }

    private tick() {
      const now = Date.now();
      const diff = this.target.getTime() - now;
      const isPast = diff <= 0;

      const digitsEl = this.querySelector('[data-digits]') as HTMLElement;
      const happenedEl = this.querySelector('[data-happened]') as HTMLElement;

      if (isPast) {
        // Switch to count-up mode
        const elapsed = Math.abs(diff);
        this.render(elapsed, true);
        digitsEl.classList.add('count-up');
        happenedEl.style.display = '';
        happenedEl.setAttribute('aria-hidden', 'false');
      } else {
        this.render(diff, false);
        digitsEl.classList.remove('count-up');
        happenedEl.style.display = 'none';
        happenedEl.setAttribute('aria-hidden', 'true');
      }
    }

    private render(ms: number, isCountUp: boolean) {
      const totalSec = Math.floor(ms / 1000);
      const days = Math.floor(totalSec / 86400);
      const hours = Math.floor((totalSec % 86400) / 3600);
      const minutes = Math.floor((totalSec % 3600) / 60);
      const seconds = totalSec % 60;

      const values: Record<string, string> = {
        days: String(days),
        hours: String(hours).padStart(2, '0'),
        minutes: String(minutes).padStart(2, '0'),
        seconds: String(seconds).padStart(2, '0'),
      };

      const labels: Record<string, [string, string]> = {
        days:    isCountUp ? ['Jours', 'écoulés']  : ['Jours', ''],
        hours:   isCountUp ? ['Heures', 'écoulées'] : ['Heures', ''],
        minutes: isCountUp ? ['Min', 'écoulées']    : ['Min', ''],
        seconds: isCountUp ? ['Sec', 'écoulées']    : ['Sec', ''],
      };

      for (const [unit, val] of Object.entries(values)) {
        const el = this.querySelector(`[data-unit="${unit}"]`) as HTMLElement;
        if (!el) continue;

        if (this.previous[unit] !== val) {
          el.textContent = val;
          // Trigger tick animation
          el.removeAttribute('data-changed');
          void el.offsetWidth; // force reflow
          el.setAttribute('data-changed', '');
          this.previous[unit] = val;
        }

        // Update label if count-up
        const labelEl = el.parentElement?.querySelector('.digit-label');
        if (labelEl && labels[unit]) {
          labelEl.textContent = labels[unit][0];
        }
      }

      // Update aria label for screen readers (throttled to every 30s for non-seconds)
      const id = this.dataset.id;
      const prefix = isCountUp ? 'Depuis' : 'Dans';
      this.setAttribute('aria-label',
        `${prefix} ${values.days} jours, ${values.hours} heures, ${values.minutes} minutes, ${values.seconds} secondes`
      );
    }
  }

  customElements.define('countdown-timer', CountdownTimer);
</script>
