---
import CountdownTimer from './CountdownTimer.astro';
import { t, localePath, dateLocale, type Locale } from '../i18n';

interface Props {
  nom: string;
  slug: string;
  dateIso: string;
  fuseau: string;
  confirme: boolean;
  descriptionCourte: string;
  linked?: boolean;
  locale: Locale;
}

const { nom, slug, dateIso, fuseau, confirme, descriptionCourte, linked = true, locale } = Astro.props;

const eventDate = new Date(dateIso);
const isPast = eventDate.getTime() < Date.now();
const displayDate = eventDate.toLocaleDateString(dateLocale(locale), {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

{linked ? (
  <a href={localePath(locale, `/${slug}/`)} class="event-card-link">
    <article class="event-card">
      <div class="meta-row">
        {confirme
          ? <span class="badge badge--confirmed">{t(locale, 'badge.confirmed')}</span>
          : <span class="badge badge--estimated">{t(locale, 'badge.estimated')}</span>
        }
        {isPast && <span class="badge badge--passed">{t(locale, 'badge.passed')}</span>}
        <time datetime={dateIso} style="font-size:0.85rem;color:var(--c-texte-secondaire)">{displayDate}</time>
      </div>

      <h2 style="margin-bottom:0.5rem">
        {nom}
        <span style="font-size:0.8em;opacity:0.5" aria-hidden="true"> &rarr;</span>
      </h2>

      <p style="color:var(--c-texte-secondaire);font-size:0.95rem;margin-bottom:1.25rem;">{descriptionCourte}</p>

      <CountdownTimer dateIso={dateIso} fuseau={fuseau} confirme={confirme} id={slug} locale={locale} />
    </article>
  </a>
) : (
  <article class="event-card">
    <div class="meta-row">
      {confirme
        ? <span class="badge badge--confirmed">{t(locale, 'badge.confirmed')}</span>
        : <span class="badge badge--estimated">{t(locale, 'badge.estimated')}</span>
      }
      {isPast && <span class="badge badge--passed">{t(locale, 'badge.passed')}</span>}
      <time datetime={dateIso} style="font-size:0.85rem;color:var(--c-texte-secondaire)">{displayDate}</time>
    </div>

    <h2 style="margin-bottom:0.5rem">{nom}</h2>

    <p style="color:var(--c-texte-secondaire);font-size:0.95rem;margin-bottom:1.25rem;">{descriptionCourte}</p>

    <CountdownTimer dateIso={dateIso} fuseau={fuseau} confirme={confirme} id={slug} locale={locale} />
  </article>
)}
