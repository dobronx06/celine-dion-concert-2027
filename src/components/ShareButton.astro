---
interface Props {
  eventName: string;
  dateIso: string;
  fuseau: string;
  url: string;
}

const { eventName, dateIso, fuseau, url } = Astro.props;
---

<share-button
  data-event={eventName}
  data-target={dateIso}
  data-tz={fuseau}
  data-url={url}
>
  <button class="share-btn" type="button" aria-label={`Partager ${eventName}`}>
    <svg class="share-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
      <polyline points="16 6 12 2 8 6"/>
      <line x1="12" y1="2" x2="12" y2="15"/>
    </svg>
    <span class="share-label">Partager</span>
  </button>
  <span class="share-toast" aria-live="polite"></span>
</share-button>

<script>
  class ShareButton extends HTMLElement {
    connectedCallback() {
      const btn = this.querySelector('.share-btn') as HTMLButtonElement;
      btn.addEventListener('click', () => this.handleShare());
    }

    private buildText(): string {
      const name = this.dataset.event!;
      const iso = this.dataset.target!;
      const tz = this.dataset.tz!;
      const target = this.resolveDate(iso, tz);
      const diff = target.getTime() - Date.now();

      if (diff <= 0) {
        return `${name} — c'est arrivé !`;
      }

      const totalSec = Math.floor(diff / 1000);
      const days = Math.floor(totalSec / 86400);
      const hours = Math.floor((totalSec % 86400) / 3600);

      if (days > 0) {
        return `Plus que ${days} jour${days > 1 ? 's' : ''} avant ${name} !`;
      }
      return `Plus que ${hours} heure${hours > 1 ? 's' : ''} avant ${name} !`;
    }

    private resolveDate(iso: string, tz: string): Date {
      const naive = new Date(iso + 'Z');
      try {
        const fmt = new Intl.DateTimeFormat('en-US', {
          timeZone: tz,
          year: 'numeric', month: '2-digit', day: '2-digit',
          hour: '2-digit', minute: '2-digit', second: '2-digit',
          hour12: false,
        });
        const parts = fmt.formatToParts(naive);
        const get = (t: string) => parts.find(p => p.type === t)?.value ?? '0';
        const localAtUTC = new Date(
          Date.UTC(+get('year'), +get('month') - 1, +get('day'),
                   +get('hour'), +get('minute'), +get('second'))
        );
        const offsetMs = localAtUTC.getTime() - naive.getTime();
        return new Date(naive.getTime() - offsetMs);
      } catch {
        return new Date(iso);
      }
    }

    private async handleShare() {
      const text = this.buildText();
      const url = this.dataset.url!;

      // Try native share (mobile & supporting desktops)
      if (navigator.share) {
        try {
          await navigator.share({ title: this.dataset.event!, text, url });
          return;
        } catch (e) {
          // User cancelled or API error — fall through to clipboard
          if ((e as DOMException).name === 'AbortError') return;
        }
      }

      // Fallback: copy to clipboard
      try {
        await navigator.clipboard.writeText(`${text}\n${url}`);
        this.showToast('Lien copié !');
      } catch {
        // Last resort fallback
        const ta = document.createElement('textarea');
        ta.value = `${text}\n${url}`;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        this.showToast('Lien copié !');
      }
    }

    private showToast(msg: string) {
      const toast = this.querySelector('.share-toast') as HTMLElement;
      toast.textContent = msg;
      toast.classList.add('share-toast--visible');
      setTimeout(() => {
        toast.classList.remove('share-toast--visible');
        toast.textContent = '';
      }, 2000);
    }
  }

  customElements.define('share-button', ShareButton);
</script>
