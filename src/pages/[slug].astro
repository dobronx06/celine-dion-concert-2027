---
import Layout from '../layouts/Layout.astro';
import CountdownTimer from '../components/CountdownTimer.astro';
import ShareButton from '../components/ShareButton.astro';
import AdSlot from '../components/AdSlot.astro';
import data from '../data/data.json';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return data.evenements.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
};

interface EventType {
  nom: string;
  slug: string;
  date_iso: string;
  fuseau: string;
  confirme: boolean;
  description_courte: string;
}

const { event } = Astro.props as { event: EventType };

const siteUrl = import.meta.env.SITE || 'https://example.com';
const eventUrl = `${siteUrl}/${event.slug}/`;
const ogImage = `/og/${event.slug}.svg`;

const eventDate = new Date(event.date_iso);
const displayDate = eventDate.toLocaleDateString('fr-FR', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

// Find adjacent events for navigation
const allEvents = data.evenements;
const currentIndex = allEvents.findIndex(e => e.slug === event.slug);
const prevEvent = currentIndex > 0 ? allEvents[currentIndex - 1] : null;
const nextEvent = currentIndex < allEvents.length - 1 ? allEvents[currentIndex + 1] : null;

// JSON-LD Event
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: event.nom,
  startDate: event.date_iso,
  description: event.description_courte,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OnlineEventAttendanceMode',
  url: eventUrl,
  location: {
    '@type': 'VirtualLocation',
    url: eventUrl,
  },
};
---

<Layout
  title={event.nom}
  description={event.description_courte}
  jsonLd={jsonLd}
  canonical={eventUrl}
  ogImage={ogImage}
  ogType="article"
>
  <div class="event-detail">
    <a href="/" class="back-link" aria-label="Retour à la liste">
      <span aria-hidden="true">&larr;</span> Tous les événements
    </a>

    <div class="meta-row">
      {event.confirme
        ? <span class="badge badge--confirmed">Date confirmée</span>
        : <span class="badge badge--estimated">Date estimée</span>
      }
      <time datetime={event.date_iso}>{displayDate}</time>
    </div>

    <h1>{event.nom}</h1>
    <p class="description">{event.description_courte}</p>

    <CountdownTimer
      dateIso={event.date_iso}
      fuseau={event.fuseau}
      confirme={event.confirme}
      id={event.slug}
    />

    <div class="share-row">
      <ShareButton
        eventName={event.nom}
        dateIso={event.date_iso}
        fuseau={event.fuseau}
        url={eventUrl}
      />
    </div>

    <AdSlot id="ad-event" format="rectangle" />

    <div class="source-link" style="margin-top:2rem;text-align:center;">
      <p>
        Source : <a href={data.source_principale} target="_blank" rel="noopener">{data.source_principale}</a>
      </p>
      <p style="margin-top:0.25rem;">Fuseau horaire de l'événement : <code>{event.fuseau}</code></p>
    </div>

    {/* Navigation between events */}
    <nav class="event-nav" aria-label="Événements adjacents">
      {prevEvent ? (
        <a href={`/${prevEvent.slug}/`}>
          <span aria-hidden="true">&larr;</span> {prevEvent.nom}
        </a>
      ) : <span />}
      {nextEvent ? (
        <a href={`/${nextEvent.slug}/`} style="text-align:right;">
          {nextEvent.nom} <span aria-hidden="true">&rarr;</span>
        </a>
      ) : <span />}
    </nav>
  </div>
</Layout>
