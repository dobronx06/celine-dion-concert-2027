---
import Layout from '../../layouts/Layout.astro';
import CountdownTimer from '../../components/CountdownTimer.astro';
import ShareButton from '../../components/ShareButton.astro';
import data from '../../data/data.json';
import { t, locales, localePath, dateLocale, type Locale } from '../../i18n';

export function getStaticPaths() {
  return locales.flatMap((lang) =>
    data.evenements.map((event) => ({
      params: { lang, slug: event.slug },
      props: { event },
    }))
  );
}

interface EventType {
  nom: string;
  slug: string;
  date_iso: string;
  fuseau: string;
  confirme: boolean;
  description_courte: string;
}

const { lang } = Astro.params;
const locale = lang as Locale;
const { event } = Astro.props as { event: EventType };

const siteUrl = import.meta.env.SITE || 'https://celineparis2027.com';
const eventUrl = `${siteUrl}${localePath(locale, `/${event.slug}/`)}`;
const ogImage = `/${locale}/og/${event.slug}.svg`;

const eventDate = new Date(event.date_iso);
const displayDate = eventDate.toLocaleDateString(dateLocale(locale), {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const allEvents = data.evenements;
const currentIndex = allEvents.findIndex(e => e.slug === event.slug);
const prevEvent = currentIndex > 0 ? allEvents[currentIndex - 1] : null;
const nextEvent = currentIndex < allEvents.length - 1 ? allEvents[currentIndex + 1] : null;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: event.nom,
  startDate: event.date_iso,
  description: event.description_courte,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OnlineEventAttendanceMode',
  url: eventUrl,
  location: { '@type': 'VirtualLocation', url: eventUrl },
};
---

<Layout
  title={event.nom}
  description={event.description_courte}
  jsonLd={jsonLd}
  canonical={eventUrl}
  ogImage={ogImage}
  ogType="article"
  locale={locale}
>
  <div class="event-detail">
    <a href={localePath(locale)} class="back-link" aria-label={t(locale, 'event.back_label')}>
      <span aria-hidden="true">&larr;</span> {t(locale, 'event.back')}
    </a>

    <div class="meta-row">
      {event.confirme
        ? <span class="badge badge--confirmed">{t(locale, 'event.confirmed')}</span>
        : <span class="badge badge--estimated">{t(locale, 'event.estimated')}</span>
      }
      <time datetime={event.date_iso}>{displayDate}</time>
    </div>

    <h1>{event.nom}</h1>
    <p class="description">{event.description_courte}</p>

    <CountdownTimer
      dateIso={event.date_iso}
      fuseau={event.fuseau}
      confirme={event.confirme}
      id={event.slug}
      locale={locale}
    />

    <div class="share-row">
      <ShareButton
        eventName={event.nom}
        dateIso={event.date_iso}
        fuseau={event.fuseau}
        url={eventUrl}
        locale={locale}
      />
    </div>

    <div class="source-link" style="margin-top:2rem;text-align:center;">
      <p>
        {t(locale, 'source')} : <a href={data.source_principale} target="_blank" rel="noopener">{data.source_principale}</a>
      </p>
      <p style="margin-top:0.25rem;">{t(locale, 'event.timezone')} <code>{event.fuseau}</code></p>
    </div>

    <nav class="event-nav" aria-label={t(locale, 'event.nav_label')}>
      {prevEvent ? (
        <a href={localePath(locale, `/${prevEvent.slug}/`)}>
          <span aria-hidden="true">&larr;</span> {prevEvent.nom}
        </a>
      ) : <span />}
      {nextEvent ? (
        <a href={localePath(locale, `/${nextEvent.slug}/`)} style="text-align:right;">
          {nextEvent.nom} <span aria-hidden="true">&rarr;</span>
        </a>
      ) : <span />}
    </nav>
  </div>
</Layout>
